---
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<div class="glass-overlay fixed inset-0 z-50 hidden items-start justify-center px-4 py-20" data-search-modal data-base-url={baseUrl}>
  <div class="panel ghost-outline w-full max-w-3xl rounded-2xl p-5 md:p-6">
    <div class="flex items-center justify-between gap-4">
      <div>
        <p class="section-eyebrow">09 // QUERY_STRING</p>
        <h2 class="mt-2 text-2xl font-semibold tracking-[-0.03em]">Search the archive</h2>
      </div>
      <button class="terminal-button" type="button" data-search-close>Esc</button>
    </div>

    <div class="search-shell mt-6">
      <span aria-hidden="true">⌕</span>
      <input
        class="w-full bg-transparent outline-none placeholder:text-[var(--fg-muted)]"
        type="search"
        name="query"
        placeholder="Type title, tag, or category..."
        data-search-input
      />
    </div>

    <ul class="mt-6 space-y-3" data-search-results>
      <li class="rounded-lg px-4 py-5 text-sm text-[var(--fg-muted)] panel-high">
        Press <span class="font-mono">Ctrl/Cmd + K</span> to open search from anywhere.
      </li>
    </ul>
  </div>
</div>

<script>
  type SearchDocument = {
    title: string;
    description: string;
    category: string;
    tags: string[];
    slug: string;
    date: string;
  };

  const modal = document.querySelector("[data-search-modal]");
  const input = modal?.querySelector("[data-search-input]") as HTMLInputElement | null;
  const results = modal?.querySelector("[data-search-results]") as HTMLUListElement | null;
  const openers = [...document.querySelectorAll("[data-search-open]")];
  const closers = [...document.querySelectorAll("[data-search-close]")];
  const baseUrl = modal?.getAttribute("data-base-url") ?? "/";

  let fuse: import("fuse.js").default<SearchDocument> | null = null;
  let documents: SearchDocument[] = [];
  let activeIndex = -1;

  const ensureSearch = async () => {
    if (fuse) {
      return;
    }

    const [{ default: Fuse }, response] = await Promise.all([
      import("fuse.js"),
      fetch(`${baseUrl}search-index.json`)
    ]) as [typeof import("fuse.js"), Response];

    documents = await response.json();
    fuse = new Fuse(documents, {
      keys: ["title", "description", "category", "tags"],
      threshold: 0.32,
      ignoreLocation: true
    });
  };

  const renderResults = (items: SearchDocument[]) => {
    if (!results) {
      return;
    }

    if (!items.length) {
      results.innerHTML = `
        <li class="rounded-lg px-4 py-5 text-sm text-[var(--fg-muted)] panel-high">
          No records found for the current query.
        </li>
      `;
      activeIndex = -1;
      return;
    }

    results.innerHTML = items
      .map(
        (item: SearchDocument, index: number) => `
          <li>
            <a
              href="${baseUrl}posts/${item.slug}/"
              class="story-card block ${index === activeIndex ? "panel-high" : ""}"
              data-search-result
            >
              <div class="flex items-center gap-3">
                <span class="section-eyebrow text-[var(--color-tertiary)]">${String(index + 1).padStart(2, "0")}</span>
                <span class="terminal-copy">${item.date}</span>
              </div>
              <h3 class="mt-3 text-xl font-semibold tracking-[-0.03em] text-[var(--fg-default)]">${item.title}</h3>
              <p class="mt-2 text-sm text-[var(--fg-muted)]">${item.description}</p>
            </a>
          </li>
        `
      )
      .join("");
  };

  const close = () => {
    modal?.classList.add("hidden");
    modal?.classList.remove("flex");
    document.documentElement.classList.remove("overflow-hidden");
    activeIndex = -1;
  };

  const open = async () => {
    await ensureSearch();
    modal?.classList.remove("hidden");
    modal?.classList.add("flex");
    document.documentElement.classList.add("overflow-hidden");
    input?.focus();
    renderResults(documents.slice(0, 6));
  };

  openers.forEach((button) => button.addEventListener("click", open));
  closers.forEach((button) => button.addEventListener("click", close));

  modal?.addEventListener("click", (event) => {
    if (event.target === modal) {
      close();
    }
  });

  window.addEventListener("keydown", async (event) => {
    if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === "k") {
      event.preventDefault();
      await open();
    }

    if (event.key === "Escape") {
      close();
    }
  });

  input?.addEventListener("input", () => {
    const query = input.value.trim();

    if (!query) {
      renderResults(documents.slice(0, 6));
      return;
    }

    const matches = fuse?.search(query, { limit: 8 }).map((entry) => entry.item) ?? [];
    renderResults(matches);
  });
</script>
