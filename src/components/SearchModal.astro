---
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const searchIndexUrl = `${baseUrl}search-index.json`;
const postsBaseUrl = `${baseUrl}posts/`;
---

<div
  class="glass-overlay fixed inset-0 z-50 hidden items-start justify-center px-4 py-20"
  data-search-modal
  data-search-index-url={searchIndexUrl}
  data-posts-base-url={postsBaseUrl}
>
  <div class="search-modal-card panel ghost-outline">
    <div class="search-modal-card__head">
      <div>
        <p class="search-modal-card__eyebrow">09 // 查询字符串</p>
        <h2 class="search-modal-card__title">搜索归档</h2>
      </div>
      <button class="pagination-chip" type="button" data-search-close>Esc</button>
    </div>

    <div class="search-command-bar">
      <span>$ load <strong>search-index.json</strong></span>
      <span>mode <strong>fuzzy-match</strong></span>
      <span>result cap <strong>08</strong></span>
    </div>

    <div class="search-shell">
      <span aria-hidden="true">⌕</span>
      <input
        class="w-full bg-transparent outline-none placeholder:text-[var(--fg-muted)]"
        type="search"
        name="query"
        placeholder="输入标题、标签或分类..."
        data-search-input
      />
    </div>

    <ul class="search-results" data-search-results>
      <li class="search-result-empty">
        按 <span class="font-mono">Ctrl/Cmd + K</span> 可在任意页面打开搜索。
      </li>
    </ul>
  </div>
</div>

<script>
  type SearchDocument = {
    title: string;
    description: string;
    category: string;
    tags: string[];
    slug: string;
    date: string;
  };

  const modal = document.querySelector("[data-search-modal]");
  const input = modal?.querySelector("[data-search-input]") as HTMLInputElement | null;
  const results = modal?.querySelector("[data-search-results]") as HTMLUListElement | null;
  const openers = [...document.querySelectorAll("[data-search-open]")];
  const closers = [...document.querySelectorAll("[data-search-close]")];
  const searchIndexUrl = modal?.getAttribute("data-search-index-url");
  const postsBaseUrl = modal?.getAttribute("data-posts-base-url");

  let fuse: import("fuse.js").default<SearchDocument> | null = null;
  let documents: SearchDocument[] = [];
  let visibleItems: SearchDocument[] = [];
  let activeIndex = -1;
  const isOpen = () => modal?.classList.contains("flex");

  const ensureSearch = async () => {
    if (fuse || !searchIndexUrl) {
      return;
    }

    const [{ default: Fuse }, response] = await Promise.all([
      import("fuse.js"),
      fetch(searchIndexUrl)
    ]) as [typeof import("fuse.js"), Response];

    documents = await response.json();
    fuse = new Fuse(documents, {
      keys: ["title", "description", "category", "tags"],
      threshold: 0.32,
      ignoreLocation: true
    });
  };

  const renderResults = (items: SearchDocument[]) => {
    if (!results || !postsBaseUrl) {
      return;
    }

    visibleItems = items;

    if (!items.length) {
      results.innerHTML = `
        <li class="search-result-empty">
          当前查询没有匹配结果。
        </li>
      `;
      activeIndex = -1;
      return;
    }

    if (activeIndex < 0) {
      activeIndex = 0;
    }

    if (activeIndex >= items.length) {
      activeIndex = items.length - 1;
    }

    results.innerHTML = items
      .map(
        (item: SearchDocument, index: number) => `
          <li>
            <a
              href="${postsBaseUrl}${item.slug}/"
              class="search-result-card ${index === activeIndex ? "is-active" : ""}"
              data-search-result
            >
              <div class="search-result-card__meta">
                <span>${String(index + 1).padStart(2, "0")}</span>
                <span>${item.date}</span>
                <span>${item.category}</span>
              </div>
              <h3 class="search-result-card__title">${item.title}</h3>
              <p class="search-result-card__summary">${item.description}</p>
            </a>
          </li>
        `
      )
      .join("");
  };

  const close = () => {
    modal?.classList.add("hidden");
    modal?.classList.remove("flex");
    document.documentElement.classList.remove("overflow-hidden");
    input && (input.value = "");
    activeIndex = -1;
  };

  const open = async () => {
    if (!searchIndexUrl || !postsBaseUrl) {
      return;
    }

    await ensureSearch();
    modal?.classList.remove("hidden");
    modal?.classList.add("flex");
    document.documentElement.classList.add("overflow-hidden");
    input?.focus();
    activeIndex = 0;
    renderResults(documents.slice(0, 6));
  };

  const syncResults = () => {
    const query = input?.value.trim() ?? "";

    if (!query) {
      activeIndex = 0;
      renderResults(documents.slice(0, 6));
      return;
    }

    const matches = fuse?.search(query, { limit: 8 }).map((entry) => entry.item) ?? [];
    activeIndex = matches.length ? 0 : -1;
    renderResults(matches);
  };

  const moveSelection = (direction: number) => {
    if (!visibleItems.length) {
      return;
    }

    activeIndex = (activeIndex + direction + visibleItems.length) % visibleItems.length;
    renderResults(visibleItems);
  };

  const openActiveResult = () => {
    if (!postsBaseUrl) {
      return;
    }

    const nextItem = visibleItems[activeIndex];

    if (nextItem) {
      window.location.href = `${postsBaseUrl}${nextItem.slug}/`;
    }
  };

  openers.forEach((button) => button.addEventListener("click", open));
  closers.forEach((button) => button.addEventListener("click", close));

  modal?.addEventListener("click", (event) => {
    if (event.target === modal) {
      close();
    }
  });

  window.addEventListener("keydown", async (event) => {
    if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === "k") {
      event.preventDefault();
      await open();
    }

    if (!isOpen()) {
      return;
    }

    if (event.key === "Escape") {
      close();
      return;
    }

    if (event.key === "ArrowDown") {
      event.preventDefault();
      moveSelection(1);
      return;
    }

    if (event.key === "ArrowUp") {
      event.preventDefault();
      moveSelection(-1);
      return;
    }

    if (event.key === "Enter" && activeIndex >= 0) {
      event.preventDefault();
      openActiveResult();
    }
  });

  input?.addEventListener("input", syncResults);
</script>
