---
import { getPageUrl } from "../utils/posts";

const { currentPage, totalPages, variant = "dashboard" } = Astro.props as {
  currentPage: number;
  totalPages: number;
  variant?: "dashboard" | "archive";
};

const pageNumbers = Array.from({ length: totalPages }, (_, index) => index + 1);
---

{
  totalPages > 1 && (
    <nav class:list={["pagination-strip", "panel", "ghost-outline", variant === "archive" ? "is-archive" : "is-dashboard"]}>
      <a
        class="pagination-chip"
        href={currentPage > 1 ? getPageUrl(currentPage - 1) : "#"}
        aria-disabled={currentPage === 1}
      >
        ← 上一页
      </a>
      <div class="pagination-pages">
        {pageNumbers.map((page) => (
          <a
            class="pagination-chip"
            href={getPageUrl(page)}
            data-active={page === currentPage}
            aria-current={page === currentPage ? "page" : undefined}
          >
            {String(page).padStart(2, "0")}
          </a>
        ))}
      </div>
      <a
        class="pagination-chip"
        href={currentPage < totalPages ? getPageUrl(currentPage + 1) : "#"}
        aria-disabled={currentPage === totalPages}
      >
        下一页 →
      </a>
    </nav>
  )
}
