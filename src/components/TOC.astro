---
type Heading = {
  slug: string;
  text: string;
  depth: number;
};

type Variant = "mobile" | "desktop" | "both";

const { headings = [], variant = "both" } = Astro.props as { headings: Heading[]; variant?: Variant };
const showMobile = variant !== "desktop";
const showDesktop = variant !== "mobile";
---

{
  headings.length > 0 && showMobile && (
    <details class="toc-panel toc-panel--mobile panel ghost-outline lg:hidden">
      <summary class="toc-panel__title">&gt; 目录</summary>
      <nav class="toc-list">
        {headings.map((heading: Heading) => (
          <a
            href={`#${heading.slug}`}
            class="toc-link"
            style={`padding-left: ${(heading.depth - 2) * 0.9}rem;`}
          >
            {heading.text}
          </a>
        ))}
      </nav>
    </details>
  )
}

{
  headings.length > 0 && showDesktop && (
    <section class="toc-panel toc-panel--desktop panel ghost-outline hidden lg:block">
      <p class="toc-panel__title">&gt; 目录</p>
      <nav class="toc-list">
        {headings.map((heading: Heading) => (
          <a
            href={`#${heading.slug}`}
            class="toc-link"
            style={`padding-left: ${(heading.depth - 2) * 0.9}rem;`}
          >
            {heading.text}
          </a>
        ))}
      </nav>
    </section>
  )
}
