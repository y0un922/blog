---
type Heading = {
  slug: string;
  text: string;
  depth: number;
};

const { headings = [] } = Astro.props as { headings: Heading[] };
---

{
  headings.length > 0 && (
    <>
      <details class="panel ghost-outline rounded-lg p-4 lg:hidden">
        <summary class="section-eyebrow cursor-pointer">02 // TABLE_OF_CONTENTS</summary>
        <nav class="mt-4 space-y-2">
          {headings.map((heading: Heading) => (
            <a
              href={`#${heading.slug}`}
              class="block text-sm text-[var(--fg-muted)] transition hover:text-[var(--fg-default)]"
              style={`padding-left: ${(heading.depth - 2) * 0.9}rem;`}
            >
              {heading.text}
            </a>
          ))}
        </nav>
      </details>

      <aside class="hidden lg:block lg:sticky lg:top-28">
        <div class="panel ghost-outline rounded-lg p-5">
          <p class="section-eyebrow">02 // TABLE_OF_CONTENTS</p>
          <nav class="mt-4 space-y-2">
            {headings.map((heading: Heading) => (
              <a
                href={`#${heading.slug}`}
                class="block text-sm text-[var(--fg-muted)] transition hover:text-[var(--fg-default)]"
                style={`padding-left: ${(heading.depth - 2) * 0.9}rem;`}
              >
                {heading.text}
              </a>
            ))}
          </nav>
        </div>
      </aside>
    </>
  )
}
