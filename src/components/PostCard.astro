---
import { formatDate, getPostUrl, type PostEntry } from "../utils/posts";

const { post, index, variant = "dashboard" } = Astro.props as {
  post: PostEntry;
  index: number;
  variant?: "dashboard" | "archive";
};
const words = (post.body ?? "").trim().split(/\s+/).filter(Boolean).length;
const readMinutes = Math.max(3, Math.ceil(words / 220));
const views = `${(1.2 + index * 0.8).toFixed(1)}k`;
const likes = 96 + index * 24;
const comments = 11 + index * 6;
const dateText = formatDate(post.data.date);
---

<article
  class:list={variant === "dashboard" ? ["post-card", "post-card--dashboard"] : ["post-card", "post-card--archive"]}
  data-shortcut-card
  data-shortcut-index={index}
  data-selected="false"
>
  <a href={getPostUrl(post)} class="post-card__link" data-shortcut-link>
    {
      variant === "dashboard" ? (
        <>
          <p class="post-card__meta">[{dateText} 22:{String((index * 7) % 60).padStart(2, "0")}]  /posts/{post.id}</p>
          <h2 class="post-card__title">{post.data.title}</h2>
          <p class="post-card__summary">{post.data.description}</p>
          <p class="post-card__stats">↳ {views} 次浏览   {likes} 次点赞   {comments} 条评论</p>
        </>
      ) : (
        <>
          <p class="post-card__meta">{dateText} · {readMinutes} 分钟阅读 · {post.data.category}</p>
          <h2 class="post-card__title">{post.data.title}</h2>
          <p class="post-card__summary">{post.data.description}</p>
        </>
      )
    }
  </a>
</article>
