---
import { formatDate, getCategoryUrl, type CategorySummary } from "../utils/posts";

type SiteStats = {
  totalPosts: number;
  totalCategories: number;
  totalTags: number;
  latest: Date | null;
};

const { categories = [], siteStats } = Astro.props as {
  categories: CategorySummary[];
  siteStats: SiteStats;
};
const latest = siteStats.latest ? formatDate(siteStats.latest) : "N/A";
---

<aside class="space-y-6">
  <section class="panel ghost-outline rounded-lg p-5">
    <p class="section-eyebrow">00 // BOOT_RECORD</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-[-0.05em] md:text-5xl">y0un92</h1>
    <p class="mt-4 max-w-xs text-sm text-[var(--fg-muted)]">
      A terminal editorial blog for engineering notes, layout experiments, and low-noise technical writing.
    </p>
  </section>

  <section class="panel ghost-outline rounded-lg p-5">
    <div class="flex items-center justify-between gap-3">
      <p class="section-eyebrow">01 // SEARCH</p>
      <button class="terminal-button" type="button" data-search-open>
        <span aria-hidden="true">⌕</span>
        <span>Open</span>
      </button>
    </div>
    <button class="search-shell mt-4 w-full text-left" type="button" data-search-open>
      <span aria-hidden="true">></span>
      <span>QUERY_STRING...</span>
    </button>
  </section>

  <section class="panel ghost-outline rounded-lg p-5">
    <p class="section-eyebrow text-[var(--color-cat-green)]">02 // SYSTEM_SPECS</p>
    <dl class="mt-4 space-y-4 text-sm text-[var(--fg-muted)]">
      <div class="flex items-center justify-between gap-4">
        <dt class="terminal-copy">POSTS</dt>
        <dd>{siteStats.totalPosts}</dd>
      </div>
      <div class="flex items-center justify-between gap-4">
        <dt class="terminal-copy">CATEGORIES</dt>
        <dd>{siteStats.totalCategories}</dd>
      </div>
      <div class="flex items-center justify-between gap-4">
        <dt class="terminal-copy">TAGS</dt>
        <dd>{siteStats.totalTags}</dd>
      </div>
      <div class="flex items-center justify-between gap-4">
        <dt class="terminal-copy">LAST_SYNC</dt>
        <dd>{latest}</dd>
      </div>
    </dl>
  </section>

  <section class="panel ghost-outline rounded-lg p-5">
    <p class="section-eyebrow text-[var(--color-cat-blue)]">03 // INDEX</p>
    <div class="mt-4 space-y-3">
      {categories.map((category: CategorySummary, index: number) => (
        <a class="flex items-center justify-between gap-4 text-sm text-[var(--fg-muted)] transition hover:text-[var(--fg-default)]" href={getCategoryUrl(category.slug)}>
          <span class="font-mono text-xs uppercase tracking-[0.12em]">
            {String(index + 1).padStart(2, "0")}. {category.slug}
          </span>
          <span>{category.count}</span>
        </a>
      ))}
    </div>
  </section>
</aside>
