---
import PageLayout from "../layouts/PageLayout.astro";
import { getPublishedPosts, getSiteStats, groupByCategory, withBase } from "../utils/posts";

const posts = await getPublishedPosts();
const categories = groupByCategory(posts);
const siteStats = getSiteStats(posts);
---

<PageLayout
  title="About | y0un92"
  description="About the author and the terminal editorial system."
  currentPath={withBase("/about/")}
  categories={categories}
  siteStats={siteStats}
  eyebrow="06 // ABOUT_NODE"
  pageTitle="About the operator"
  lead="This site is built as a terminal editorial notebook: technical, left-aligned, and intentionally low-noise."
>
  <section class="panel ghost-outline rounded-xl px-5 py-6 md:px-7 md:py-7">
    <div class="article-prose">
      <p>
        y0un92 writes about engineering systems, interaction design, and the tradeoffs that appear when a prototype becomes a real product.
      </p>
      <p>
        The blog is authored in Markdown, generated with Astro, and shaped by a terminal-inspired editorial rhythm instead of a generic app dashboard.
      </p>
      <p>
        The current version prioritizes readable long-form posts, clear taxonomy, static deployment, and a restrained interactive layer built with vanilla JavaScript.
      </p>
    </div>
  </section>
</PageLayout>
