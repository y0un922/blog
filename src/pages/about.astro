---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import { withBase } from "../utils/posts";
---

<BaseLayout
  title="About | y0un92"
  description="About the author and the terminal editorial system."
  currentPath={withBase("/about/")}
>
  <div class="simple-page-screen">
    <Navbar currentPath={withBase("/about/")} variant="compact" />

    <div class="simple-page-body">
      <section class="simple-page-main">
        <section class="about-profile-card panel ghost-outline">
          <p class="simple-page__eyebrow">关于 // Y0UN92</p>
          <div class="simple-page__copy-list">
            <span>名字: y0un92</span>
            <span>角色: 全栈开发者 / 写作者</span>
            <span>技术栈: Rust, TS, Python, Neovim</span>
          </div>
        </section>

        <p class="about-mission-copy">
          我写工程实践、键盘优先工作流，以及如何用冷静清晰的方式构建可靠系统。
        </p>
      </section>

      <aside class="simple-page-side">
        <section class="simple-side-card panel ghost-outline">
          <p class="simple-side-card__title">skills.map</p>
          <div class="simple-side-card__copy-list is-accent">
            <span>&gt; 后端        ████████░░</span>
            <span>&gt; 前端        ██████░░░░</span>
            <span>&gt; 写作        ███████░░░</span>
          </div>
        </section>

        <section class="simple-side-card panel ghost-outline">
          <p class="simple-side-card__title">当前进行中</p>
          <div class="simple-side-card__copy-list">
            <span>- 打磨键盘优先的博客 UX</span>
            <span>- 写 Rust async 笔记</span>
          </div>
        </section>
      </aside>
    </div>
  </div>
</BaseLayout>
