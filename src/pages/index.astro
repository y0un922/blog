---
import PageLayout from "../layouts/PageLayout.astro";
import Pagination from "../components/Pagination.astro";
import PostCard from "../components/PostCard.astro";
import { getPublishedPosts, getSiteStats, groupByCategory, paginatePosts, withBase } from "../utils/posts";

const posts = await getPublishedPosts();
const categories = groupByCategory(posts);
const siteStats = getSiteStats(posts);
const { items, currentPage, totalPages } = paginatePosts(posts, 1);
---

<PageLayout
  title="y0un92 // Terminal Editorial"
  description="A terminal editorial blog built with Astro, Tailwind, and Markdown."
  currentPath={withBase("/")}
  categories={categories}
  siteStats={siteStats}
  eyebrow="01 // RECENT_ARCHIVES"
  pageTitle="Transmission feed"
  lead="A left-aligned archive of engineering notes, interface decisions, and systems writing."
>
  <section class="space-y-5">
    {items.map((post, index) => <PostCard post={post} index={index + 1} />)}
  </section>
  <Pagination currentPage={currentPage} totalPages={totalPages} />
</PageLayout>
