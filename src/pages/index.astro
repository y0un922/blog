---
import PageLayout from "../layouts/PageLayout.astro";
import Pagination from "../components/Pagination.astro";
import PostCard from "../components/PostCard.astro";
import { getPublishedPosts, getSiteStats, groupByCategory, groupByTag, paginatePosts, withBase } from "../utils/posts";

const posts = await getPublishedPosts();
const categories = groupByCategory(posts);
const tags = groupByTag(posts);
const siteStats = getSiteStats(posts);
const { items, currentPage, totalPages } = paginatePosts(posts, 1);
---

<PageLayout
  title="y0un92 // Terminal Editorial"
  description="A terminal editorial blog built with Astro, Tailwind, and Markdown."
  currentPath={withBase("/")}
  categories={categories}
  posts={posts}
  tags={tags}
  siteStats={siteStats}
  variant="dashboard"
>
  <section class="dashboard-feed-list">
    {items.map((post, index) => <PostCard post={post} index={index + 1} variant="dashboard" />)}
  </section>
  <Pagination currentPage={currentPage} totalPages={totalPages} variant="dashboard" />
</PageLayout>
