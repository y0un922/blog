---
import { render } from "astro:content";
import PostLayout from "../../layouts/PostLayout.astro";
import { getAdjacentPosts, getPostUrl, getPublishedPosts } from "../../utils/posts";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post }
  }));
}

const { post } = Astro.props;
const posts = await getPublishedPosts();
const { Content, headings } = await render(post);
const { previous, next } = getAdjacentPosts(posts, post.id);
const articleUrl = getPostUrl(post);
const recentPosts = posts.filter((entry) => entry.id !== post.id).slice(0, 3);
const structuredData = Astro.site
  ? {
      "@context": "https://schema.org",
      "@type": "Article",
      headline: post.data.title,
      description: post.data.description,
      datePublished: post.data.date.toISOString(),
      articleSection: post.data.category,
      keywords: post.data.tags.join(", "),
      author: {
        "@type": "Person",
        name: "y0un92"
      },
      url: new URL(articleUrl, Astro.site).toString()
    }
  : null;
---

<PostLayout
  post={post}
  headings={headings}
  previous={previous}
  next={next}
  recentPosts={recentPosts}
  currentPath={articleUrl}
  structuredData={structuredData}
>
  <Content />
</PostLayout>
