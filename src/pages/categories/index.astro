---
import PageLayout from "../../layouts/PageLayout.astro";
import { getPublishedPosts, getSiteStats, groupByCategory, getCategoryUrl, withBase } from "../../utils/posts";

const posts = await getPublishedPosts();
const categories = groupByCategory(posts);
const siteStats = getSiteStats(posts);
const chips = [
  { label: "全部", href: withBase("/") },
  { label: "分类", active: true },
  { label: "最近" }
];
---

<PageLayout
  title="Categories | y0un92"
  description="Browse all archive categories."
  currentPath={withBase("/categories/")}
  categories={categories}
  posts={posts}
  siteStats={siteStats}
  variant="archive"
  toolbarLabel="筛选: 分类"
  chips={chips}
>
  <section class="archive-list">
    {categories.map((category, index) => (
      <a class="taxonomy-entry panel ghost-outline" href={getCategoryUrl(category.slug)}>
        <p class="taxonomy-entry__meta">{String(index + 1).padStart(2, "0")} · 分类节点</p>
        <h2 class="taxonomy-entry__title">{category.slug}</h2>
        <p class="taxonomy-entry__summary">{category.count} 篇已发布文章。</p>
      </a>
    ))}
  </section>
</PageLayout>
