---
import PageLayout from "../../layouts/PageLayout.astro";
import { getPublishedPosts, getSiteStats, groupByCategory, getCategoryUrl, withBase } from "../../utils/posts";

const posts = await getPublishedPosts();
const categories = groupByCategory(posts);
const siteStats = getSiteStats(posts);
---

<PageLayout
  title="Categories | y0un92"
  description="Browse all archive categories."
  currentPath={withBase("/categories/")}
  categories={categories}
  siteStats={siteStats}
  eyebrow="04 // CATEGORY_INDEX"
  pageTitle="Folder overview"
  lead="All archive folders generated from the published post taxonomy."
>
  <section class="grid gap-4 md:grid-cols-2">
    {categories.map((category, index) => (
      <a class="story-card" href={getCategoryUrl(category.slug)}>
        <p class="section-eyebrow">{String(index + 1).padStart(2, "0")} // {category.slug}</p>
        <p class="mt-4 text-lg font-semibold tracking-[-0.03em]">{category.count} published entries</p>
      </a>
    ))}
  </section>
</PageLayout>
