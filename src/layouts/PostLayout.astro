---
import BaseLayout from "./BaseLayout.astro";
import {
  formatDate,
  getCategoryUrl,
  getPostUrl,
  getTagUrl,
  type PostEntry,
  withBase
} from "../utils/posts";

const {
  post,
  previous,
  next,
  recentPosts = [],
  currentPath,
  structuredData
} = Astro.props as {
  post: PostEntry;
  previous: PostEntry | null;
  next: PostEntry | null;
  recentPosts?: PostEntry[];
  currentPath: string;
  structuredData: Record<string, unknown> | null;
};

const publishedAt = formatDate(post.data.date);
const words = (post.body ?? "").trim().split(/\s+/).filter(Boolean).length;
const readMinutes = Math.max(3, Math.ceil(words / 220));
const wordCount = new Intl.NumberFormat("en-US").format(words);
const categoryHref = getCategoryUrl(post.data.category);
const categoryChips = [
  {
    label: post.data.category,
    href: categoryHref,
    active: true
  },
  ...post.data.tags.slice(0, 4).map((tag) => ({
    label: tag,
    href: getTagUrl(tag),
    active: false
  }))
];
---

<BaseLayout
  title={`${post.data.title} | y0un92`}
  description={post.data.description}
  currentPath={currentPath}
  structuredData={structuredData}
>
  <div class="archive-screen archive-screen--detail">
    <header class="post-detail-header panel ghost-outline">
      <p class="post-detail-header__title">{`cat ./posts/${post.id}.md`}</p>
      <p class="post-detail-header__subtitle">ARTICLE_VIEW // 阅读模式</p>
    </header>

    <div class="archive-body">
      <article class="archive-left detail-left">
        <div class="archive-toolbar panel ghost-outline">
          <div class="post-detail-breadcrumbs">
            <a href={withBase("/")}>[ 博客首页 ]</a>
            <span>/</span>
            <a href={categoryHref}>{`[ ${post.data.category} ]`}</a>
            <span>/</span>
            <span>[ 正文 ]</span>
          </div>
        </div>

        <div class="archive-chip-row">
          <span class="archive-chip" data-active="true">{publishedAt}</span>
          <span class="archive-chip">{`${readMinutes} 分钟阅读`}</span>
          <span class="archive-chip">{`${wordCount} 字`}</span>
        </div>

        <section class="detail-article panel ghost-outline">
          <h1 class="detail-article__title">{post.data.title}</h1>
          <p class="detail-article__lead">{post.data.description}</p>
          <div class="detail-article__separator" aria-hidden="true"></div>

          <div class="article-prose">
            <slot />
          </div>

          <nav class="detail-article__pager">
            <a href={previous ? getPostUrl(previous) : "#"} aria-disabled={!previous}>
              {previous ? `← 上一篇：${previous.data.title}` : "← 上一篇：暂无"}
            </a>
            <a href={next ? getPostUrl(next) : "#"} aria-disabled={!next}>
              {next ? `下一篇：${next.data.title} →` : "下一篇：暂无 →"}
            </a>
          </nav>
        </section>
      </article>

      <aside class="archive-right detail-right">
        <section class="archive-side-card panel ghost-outline">
          <p class="archive-side-card__title">&gt; 搜索</p>
          <button class="archive-search-button" type="button" data-search-open>
            <span>搜索文章...</span>
          </button>
        </section>

        <section class="archive-side-card panel ghost-outline">
          <p class="archive-side-card__title">&gt; 分类</p>
          <div class="archive-side-chip-list">
            {categoryChips.map((chip) => (
              <a href={chip.href} class="archive-side-chip" data-active={chip.active}>
                {chip.label}
              </a>
            ))}
          </div>
        </section>

        <section class="archive-side-card panel ghost-outline">
          <p class="archive-side-card__title">&gt; 最近文章</p>
          <div class="archive-side-copy-list">
            {recentPosts.map((entry, index) => (
              <a href={getPostUrl(entry)}>{`[${index + 1}] ${entry.data.title}`}</a>
            ))}
          </div>
        </section>

        <section class="archive-side-card archive-side-card--accent panel ghost-outline">
          <p class="archive-side-card__title">&gt; 订阅</p>
          <p class="archive-side-card__body">每周一封邮件，推送终端技巧与新文章。</p>
          <button class="archive-subscribe-button" type="button" data-search-open>订阅更新</button>
        </section>
      </aside>
    </div>
  </div>
</BaseLayout>
