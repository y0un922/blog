---
import BaseLayout from "./BaseLayout.astro";
import TOC from "../components/TOC.astro";
import TagBadge from "../components/TagBadge.astro";
import { formatDate, getPostUrl, type PostEntry } from "../utils/posts";

const {
  post,
  headings,
  previous,
  next,
  currentPath,
  structuredData
} = Astro.props as {
  post: PostEntry;
  headings: { slug: string; text: string; depth: number }[];
  previous: PostEntry | null;
  next: PostEntry | null;
  currentPath: string;
  structuredData: Record<string, unknown> | null;
};
---

<BaseLayout
  title={`${post.data.title} | y0un92`}
  description={post.data.description}
  currentPath={currentPath}
  structuredData={structuredData}
>
  <div class="editorial-grid post-view">
    <article class="space-y-6">
      <header class="panel ghost-outline rounded-xl px-5 py-6 md:px-7 md:py-7">
        <p class="section-eyebrow">01 // POST</p>
        <h1 class="mt-4 text-4xl font-semibold tracking-[-0.05em] md:text-5xl">{post.data.title}</h1>
        <div class="mt-5 flex flex-wrap items-center gap-3 text-sm text-[var(--fg-muted)]">
          <span class="terminal-copy">{formatDate(post.data.date)}</span>
          <span class="terminal-copy">{post.data.category}</span>
          {post.data.tags.map((tag: string) => <TagBadge tag={tag} />)}
        </div>
        <p class="mt-5 max-w-3xl text-sm text-[var(--fg-muted)] md:text-base">{post.data.description}</p>
      </header>

      <section class="panel ghost-outline rounded-xl px-5 py-6 md:px-7 md:py-7">
        <div class="article-prose">
          <slot />
        </div>
      </section>

      <nav class="grid gap-4 md:grid-cols-2">
        <a class="story-card" href={previous ? getPostUrl(previous) : "#"} aria-disabled={!previous}>
          <p class="section-eyebrow">Prev</p>
          <h2 class="mt-3 text-xl font-semibold tracking-[-0.03em]">{previous?.data.title ?? "No previous post"}</h2>
        </a>
        <a class="story-card" href={next ? getPostUrl(next) : "#"} aria-disabled={!next}>
          <p class="section-eyebrow">Next</p>
          <h2 class="mt-3 text-xl font-semibold tracking-[-0.03em]">{next?.data.title ?? "No newer post"}</h2>
        </a>
      </nav>
    </article>

    <TOC headings={headings} />
  </div>
</BaseLayout>
